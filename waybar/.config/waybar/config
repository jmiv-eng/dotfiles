{
    "layer": "top",
    "position": "top",
    
    // Remove width to fix the second monitor truncation
    // "width": 1280, 

    "modules-left": [
        "sway/workspaces",
        "sway/mode"
    ],
    "modules-center": [],
    "modules-right": [
		"pulseaudio",
		"custom/sway_audio_idle_inhibit",
        "network",
        "cpu",
        "memory",
        "temperature#gpu",  // New GPU Temp
        "temperature#cpu",  // Renamed your old temp to CPU
		"clock",
        "tray"
    ],

    // --- MODULE CONFIGURATION ---

    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },

    "clock": {
        "format": "{:%H:%M:%S %Y-%m-%d}",
        "interval": 1,
        "max-length": 35
    },

    "cpu": {
        "format": "{usage}% ´őŤ",
        "tooltip": false
    },

    "memory": {
        "format": "{}% ´âë"
    },

    // --- GPU CONFIGURATION ---
	"temperature#gpu": {
		// The stable path you found via readlink
		"hwmon-path-abs": "/sys/devices/pci0000:00/0000:00:03.1/0000:0a:00.0/0000:0b:00.0/0000:0c:00.0/hwmon",
		"input-filename": "temp1_input",
		"critical-threshold": 80,
		"format": "{temperatureC}┬░C ´üş",
		"format-critical": "{temperatureC}┬░C ´üş",
		"interval": 2,
		"tooltip": true
	},

    // --- CPU CONFIGURATION ---
    "temperature#cpu": {
        "thermal-zone": 2,
        // This path is likely your CPU
        "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
        "critical-threshold": 80,
        "format": "{temperatureC}┬░C ´őë",
        "format-critical": "{temperatureC}┬░C ´őë",
        "format-icons": ["´Łź", "´őë", "´Łę"]
    },

    // --- SYSTEM UTILS ---

    "tray": {
        "icon-size": 21,
        "spacing": 10
    },

    "network": {
        "format-wifi": "({signalStrength}%) ´çź",
        "format-ethernet": "{ifname}: {ipaddr}/{cidr} ´×ľ",
        "format-linked": "{ifname} (No IP) ´×ľ",
        "format-disconnected": "ÔÜá",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "max-length": 30
    },

    "pulseaudio": {
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon}´Őö {format_source}",
        "format-bluetooth-muted": "´Üę {icon}´Őö {format_source}",
        "format-muted": "´Üę {format_source}",
        "format-source": "{volume}% ´ä░",
        "format-source-muted": "´ä▒",
        "format-icons": {
            "headphone": "´Çą",
            "hands-free": "´ľÉ",
            "headset": "´ľÉ",
            "phone": "´éĽ",
            "portable": "´éĽ",
            "car": "´ć╣",
            "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
        },
        "on-click": "pavucontrol"
    },

    "custom/sway_audio_idle_inhibit": {
        "format": "{icon}",
        "exec": "sway-audio-idle-inhibit --dry-print-both-waybar",
        "exec-if": "which sway-audio-idle-inhibit",
        "return-type": "json",
        "format-icons": {
            "output": "´ůä",
            "input": "´ä░",
            "output-input": "´ůä  ´ä░",
            "none": ""
        }
    }
}
