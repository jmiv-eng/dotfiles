{
    "include": ["~/.config/waybar/machine.json"],
    "layer": "top",
    "position": "top",

    "modules-left": [
        "sway/workspaces",
        "sway/mode",
        "cpu",
        "temperature#cpu",
        "temperature#gpu"
    ],
    "modules-center": [
	],
    "modules-right": [
        "pulseaudio",
        "custom/sway_audio_idle_inhibit",
        "network",
        "memory",
        "battery",
        "clock",
        "tray"
    ],

    // --- MODULE CONFIGURATION ---

    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },

    "clock": {
        "format": "{:%H:%M:%S %Y-%m-%d}",
        "interval": 1,
        "max-length": 35
    },

    "cpu": {
        "format": "{usage}% ´őŤ",
        "tooltip": false
    },

    "memory": {
        "format": "{}% ´âë"
    },

    "temperature#cpu": {
        "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
        "critical-threshold": 80,
        "format": "{temperatureC}┬░C {icon}",
        "format-critical": "{temperatureC}┬░C {icon}",
        "format-icons": ["´őő", "´őë", "´őç"]
    },

    "temperature#gpu": {
        "hwmon-path-abs": "/sys/devices/pci0000:00/0000:00:03.1/0000:0a:00.0/0000:0b:00.0/0000:0c:00.0/hwmon",
        "input-filename": "temp1_input",
        "critical-threshold": 80,
        "format": "{temperatureC}┬░C ´őë",
        "format-critical": "{temperatureC}┬░C ´őë",
        "interval": 2,
        "tooltip": true
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% ´âž",
        "format-plugged": "{capacity}% ´çŽ",
        "format-alt": "{time} {icon}",
        "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
    },


    "tray": {
        "icon-size": 21,
        "spacing": 10
    },

    "network": {
        "format-wifi": "({signalStrength}%) ´çź",
        "format-ethernet": "{ifname}: {ipaddr}/{cidr} ´×ľ",
        "format-linked": "{ifname} (No IP) ´×ľ",
        "format-disconnected": "ÔÜá",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "max-length": 30
    },

    "pulseaudio": {
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon}´Őö {format_source}",
        "format-bluetooth-muted": "´Üę {icon}´Őö {format_source}",
        "format-muted": "´Üę {format_source}",
        "format-source": "{volume}% ´ä░",
        "format-source-muted": "´ä▒",
        "format-icons": {
            "headphone": "´Çą",
            "hands-free": "´ľÉ",
            "headset": "´ľÉ",
            "phone": "´éĽ",
            "portable": "´éĽ",
            "car": "´ć╣",
            "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
        },
        "on-click": "pavucontrol"
    },

    "custom/sway_audio_idle_inhibit": {
        "format": "{icon}",
        "exec": "sway-audio-idle-inhibit --dry-print-both-waybar",
        "exec-if": "which sway-audio-idle-inhibit",
        "return-type": "json",
        "format-icons": {
            "output": "´ůä",
            "input": "´ä░",
            "output-input": "´ůä  ´ä░",
            "none": ""
        }
    }
}
